{
    "name"        : "BX AI Sentinel Middleware",
    "slug"        : "bx-aisentinel",
    "version"     : "1.0.0",
    "author"      : "Michael Rigsby <mrigsby@oistech.com>",
    "location"    : "forgeboxStorage",
    "homepage"    : "https://www.oistech.com",
    "description" : "BoxLang AI middleware that tokenizes secrets, credentials, and PII in outbound LLM prompts and restores them on the inbound response. Drop-in, provider-agnostic, per-call timing metrics.",
    "type"        : "modules",
    "directory"   : "modules_app",
    "keywords"    : [
        "boxlang",
        "bx-ai",
        "ai",
        "middleware",
        "security",
        "pii",
        "redaction",
        "tokenization",
        "secrets",
        "llm"
    ],
    "dependencies": {
        "bx-ai": "^1.0.0"
    },
    "devDependencies": {
        "testbox": "^7.0.0"
    },
    "license": [
        {
            "type": "Apache2",
            "url" : "https://www.apache.org/licenses/LICENSE-2.0"
        }
    ],
    "testbox": {
        "runner": [
            { "default": "http://localhost:8080/tests/runner.bxm" }
        ]
    },
    "ignore": [
        "**/.*",
        "tests"
    ],
    "scripts": {
        "test": "testbox run"
    }
}
