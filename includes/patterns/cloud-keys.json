    "patterns": [
        {
            "label"      : "AWS_ACCESS_KEY",
            "category"   : "cloud-keys",
            "regex"      : "AKIA[0-9A-Z]{16}",
            "confidence" : 0.98,
            "description": "AWS IAM access key ID"
        },
        {
            "label"      : "AWS_ACCESS_KEY_TEMP",
            "category"   : "cloud-keys",
            "regex"      : "ASIA[0-9A-Z]{16}",
            "confidence" : 0.98,
            "description": "AWS STS temporary access key ID"
        },
        {
            "label"      : "GCP_SERVICE_ACCOUNT_JSON",
            "category"   : "cloud-keys",
            "regex"      : "\"type\"\\s*:\\s*\"service_account\"",
            "confidence" : 0.85,
            "description": "GCP service account JSON block marker"
        },
        {
            "label"      : "AZURE_STORAGE_CONN_STRING",
            "category"   : "cloud-keys",
            "regex"      : "DefaultEndpointsProtocol=https;AccountName=[A-Za-z0-9]+;AccountKey=[A-Za-z0-9+/=]{40,}",
            "confidence" : 0.97,
            "description": "Azure storage account connection string"
        }
    ]
}
