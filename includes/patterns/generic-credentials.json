{
    "_meta": {
        "source"      : "gitleaks (MIT) + detect-secrets (Apache-2.0), adapted",
        "license"     : "bundled under Apache-2.0 per module license",
        "lastUpdated" : "2026-04-17"
    },
    "patterns": [
        {
            "label"      : "JWT",
            "category"   : "generic",
            "regex"      : "eyJ[A-Za-z0-9_\\-]+\\.eyJ[A-Za-z0-9_\\-]+\\.[A-Za-z0-9_\\-]+",
            "confidence" : 0.97,
            "description": "JSON Web Token (three-segment base64url)"
        },
        {
            "label"      : "PEM_PRIVATE_KEY",
            "category"   : "generic",
            "regex"      : "(?s)-----BEGIN[ A-Z]* PRIVATE KEY-----.*?-----END[ A-Z]* PRIVATE KEY-----",
            "confidence" : 0.99,
            "description": "PEM-encoded private key (RSA / EC / DSA / OPENSSH / PGP)"
        },
        {
            "label"      : "POSTGRES_URI",
            "category"   : "generic",
            "regex"      : "postgres(?:ql)?://[^\\s:@/]+:[^\\s@]+@[^\\s/]+/\\S+",
            "confidence" : 0.97,
            "description": "PostgreSQL URI with embedded credentials"
        },
        {
            "label"      : "MYSQL_URI",
            "category"   : "generic",
            "regex"      : "mysql://[^\\s:@/]+:[^\\s@]+@[^\\s/]+/\\S+",
            "confidence" : 0.97,
            "description": "MySQL URI with embedded credentials"
        },
        {
            "label"      : "MONGODB_URI",
            "category"   : "generic",
            "regex"      : "mongodb(?:\\+srv)?://[^\\s:@/]+:[^\\s@]+@[^\\s/]+/\\S+",
            "confidence" : 0.97,
            "description": "MongoDB URI with embedded credentials"
        },
        {
            "label"      : "BASIC_AUTH_URL",
            "category"   : "generic",
            "regex"      : "https?://[^\\s:@/]+:[^\\s@/]+@[^\\s/]+",
            "confidence" : 0.9,
            "description": "HTTP URL with embedded basic-auth credentials"
        }
    ]
}
