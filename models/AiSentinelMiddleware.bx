/**
 * AiSentinelMiddleware — the bx-ai middleware adapter.
 *
 * Implements the six bx-ai lifecycle hooks and dispatches the real work into
 * `SentinelCore`. Each hook is timed; timings land on `context.metadata.sentinel.metrics`
 * and on a cached last-run struct retrievable via `getLastRunMetrics()`.
 *
 * When used outside bx-ai (unit / integration tests for the core), instantiate
 * `SentinelCore` directly.
 *
 * This class is expected to extend `bxModules.bxai.models.middleware.BaseAiMiddleware`
 * when deployed into a bx-ai agent. In this dev tree we do NOT declare the
 * `extends` attribute so the file remains loadable without a bx-ai checkout —
 * add `extends="bxModules.bxai.models.middleware.BaseAiMiddleware"` as a
 * superclass prior to publishing, or subclass this in the host project if
 * your bx-ai version expects the explicit inheritance.
 */
class {

    property name="name"            type="string"  default="AiSentinelMiddleware";
    property name="description"     type="string"  default="Redacts secrets / PII before LLM calls and restores on return.";
    property name="core"            type="any";
    property name="auditor"         type="any";
    property name="policy"          type="any";
    property name="manifestScope"   type="string"  default="run";
    property name="metricsEnabled"  type="boolean" default="true";
    property name="enabled"         type="boolean" default="true";
    property name="explainTokensToLLM" type="boolean" default="true";
    property name="tokenProtocolContent" type="string" default="";
    property name="lastRunMetrics"  type="struct";
    property name="persistentRunContext" type="any";
    property name="loadReport"      type="struct";

    // Contract version this middleware expects from external detectors.
    // See models/detectors/CONTRACT.md. Major-version must match.
    variables.SUPPORTED_CONTRACT_VERSION = "1.0.0";

    function init( struct settings = {} ) {
        variables.name        = "AiSentinelMiddleware";
        variables.description = "Redacts secrets / PII before LLM calls and restores on return.";
        variables.lastRunMetrics = {};
        variables.persistentRunContext = javaCast( "null", "" );
        variables.loadReport = {
            "compatibleContractVersion" : variables.SUPPORTED_CONTRACT_VERSION,
            "detectors"                 : [],
            "degraded"                  : false
        };

        // Resolve the effective policy: defaults → boxlang.json → .sentinel.json → constructor overrides
        variables.policy = structKeyExists( arguments.settings, "policy" )
            ? arguments.settings.policy
            : new policy.SentinelPolicy(
                overrides        : arguments.settings,
                boxlangJsonPath  : arguments.settings.boxlangJsonPath  ?: "",
                sentinelJsonPath : arguments.settings.sentinelJsonPath ?: ""
            );

        variables.manifestScope     = variables.policy.getManifestScope();
        variables.metricsEnabled    = variables.policy.isMetricsEnabled();
        variables.enabled           = arguments.settings.enabled ?: true;
        variables.explainTokensToLLM = ( structKeyExists( arguments.settings, "explainTokensToLLM" )
            ? arguments.settings.explainTokensToLLM
            : variables.policy.isTokenCoachingEnabled() );
        variables.tokenProtocolContent = _loadTokenProtocol( variables.policy.getTokenProtocolPath() );

        // Host apps can inject a pre-built core for testing / advanced use.
        if ( structKeyExists( arguments.settings, "core" ) ) {
            variables.core    = arguments.settings.core;
            variables.auditor = arguments.settings.auditor
                ?: new SentinelAuditor(
                    logFile : variables.policy.getAuditLogFile(),
                    enabled : variables.policy.isAuditEnabled()
                );
            return this;
        }

        variables.auditor = arguments.settings.auditor
            ?: new SentinelAuditor(
                logFile : variables.policy.getAuditLogFile(),
                enabled : variables.policy.isAuditEnabled()
            );

        variables.core = _composeCore( variables.policy, variables.auditor );

        return this;
    }

    /**
     * Build a SentinelCore from the resolved policy. Public for hosts that
     * want to rebuild components after mutating policy at runtime.
     */
    function _composeCore( required any policy, required any auditor ) {
        var tokenizer = new Tokenizer();
        var catalog   = new catalog.PatternCatalog().loadBundled();

        // Drop patterns whose category is disabled.
        catalog.filterByCategories( arguments.policy.getEnabledCategories() );

        // Merge any user-supplied custom patterns into the catalog.
        for ( var custom in arguments.policy.getCustomPatterns() ) {
            catalog.addPattern( custom );
        }

        var detectors = [];

        if ( arguments.policy.isRegistryDetectorEnabled() ) {
            detectors.append( new detectors.RegistryDetector( secrets: arguments.policy.getRegisteredSecrets() ) );
        }
        if ( arguments.policy.isRegexDetectorEnabled() ) {
            detectors.append( new detectors.RegexDetector( catalog: catalog ) );
        }
        if ( arguments.policy.isEntropyDetectorEnabled() && arguments.policy.isCategoryEnabled( "entropy" ) ) {
            detectors.append(
                new detectors.EntropyDetector(
                    minLength           : arguments.policy.getEntropyMinLength(),
                    threshold           : arguments.policy.getEntropyThreshold(),
                    requireMixedCharset : arguments.policy.requiresMixedCharset()
                )
            );
        }

        // External detectors from sibling modules (e.g. bx-AISentinel-ONNX).
        // Each one is resolved independently; a single broken plugin does not
        // take the sentinel down — see models/detectors/CONTRACT.md.
        var externalIds     = arguments.policy.getExternalDetectors();
        var externalOptions = arguments.policy.getExternalDetectorOptions();
        for ( var id in externalIds ) {
            var loaded = _resolveExternalDetector(
                id       : id,
                options  : structKeyExists( externalOptions, id ) ? externalOptions[ id ] : {},
                auditor  : arguments.auditor
            );
            if ( !isNull( loaded ) ) {
                detectors.append( loaded );
            }
        }

        var engine = new DetectionEngine( detectors: detectors );

        return new SentinelCore(
            tokenizer       : tokenizer,
            detectionEngine : engine,
            auditor         : arguments.auditor
        );
    }

    /**
     * Read-only access to the resolved policy — useful for diagnostics + demo UI.
     */
    function getPolicy() {
        return variables.policy;
    }

    /**
     * Runtime enable / disable. When disabled, every hook short-circuits to
     * proceed() without doing any redaction, restoration, or metric capture.
     * Lets a host UI (the demo's Sentinel toggle) flip behavior without
     * rebuilding the agent.
     */
    function setEnabled( required boolean enabled ) {
        variables.enabled = arguments.enabled;
        return this;
    }

    boolean function isEnabled() {
        return variables.enabled;
    }

    // ─────────────────────────────────────────────────────────────────────
    // bx-ai lifecycle hooks
    // ─────────────────────────────────────────────────────────────────────

    function beforeAgentRun( required struct context ) {
        if ( !variables.enabled ) return _proceed();

        if ( !structKeyExists( arguments.context, "metadata" ) ) {
            arguments.context.metadata = {};
        }

        var runCtx = _getOrCreateRunContext();
        arguments.context.metadata.sentinel = runCtx;

        return _proceed();
    }

    /**
     * bx-ai 3.x contract for beforeLLMCall:
     *   context = { chatRequest, dataPacket }
     * dataPacket is the payload going on the wire to the provider — shape
     * matches OpenAI: `{ model, messages: [ { role, content } ], ... }`.
     *
     * We redact `dataPacket.messages[].content` in place so the provider
     * never sees plaintext. bx-ai doesn't share state across hooks, so we
     * hold `runCtx` on the middleware instance (variables.persistentRunContext).
     */
    function beforeLLMCall( required struct context ) {
        if ( !variables.enabled ) return _proceed();

        var runCtx = _resolveRunContext( arguments.context );
        var start  = getTickCount();

        var messages = _extractMessagesFromContext( arguments.context );
        if ( isArray( messages ) ) {
            for ( var msg in messages ) {
                if ( structKeyExists( msg, "content" ) && isSimpleValue( msg.content ) ) {
                    msg.content = variables.core.redact( msg.content, runCtx );
                }
            }

            // Inject the token-protocol system message only when the outbound
            // payload actually contains at least one ⟦SECRET:...⟧ placeholder.
            // This covers:
            //   - tokens minted this turn (just redacted above)
            //   - tokens pulled in from earlier turns via aiMemory
            // and skips the ~80-token overhead on plain non-sensitive chat.
            var coachingApplied = false;
            if ( variables.explainTokensToLLM
                 && len( variables.tokenProtocolContent )
                 && _messagesContainTokens( messages ) ) {
                _injectTokenProtocol( messages );
                coachingApplied = true;
            }
        }

        // Snapshot of what the LLM is about to see — after redaction + (maybe) injection.
        runCtx.metrics.lastTokenizedMessages = isArray( messages ) ? duplicate( messages ) : [];
        runCtx.metrics.tokenCoachingApplied  = ( coachingApplied ?: false );

        var elapsed = getTickCount() - start;
        runCtx.metrics.outboundMs    += elapsed;
        runCtx.metrics.lastOutboundMs = elapsed;
        runCtx.metrics.lastLlmStart   = getTickCount();

        // Keep runCtx alive across hooks via the instance.
        variables.persistentRunContext = runCtx;
        variables.lastRunMetrics       = duplicate( runCtx.metrics );

        return _proceed();
    }

    /**
     * bx-ai 3.x contract for afterLLMCall:
     *   context = { chatRequest, result }
     * `result` is the parsed response struct (OpenAI-shape: choices/message/content).
     * We restore tokens in place so the caller sees plaintext.
     */
    function afterLLMCall( required struct context ) {
        if ( !variables.enabled ) return _proceed();

        var runCtx = _resolveRunContext( arguments.context );
        var start  = getTickCount();

        if ( structKeyExists( runCtx.metrics, "lastLlmStart" ) ) {
            runCtx.metrics.llmRoundtripMs = start - runCtx.metrics.lastLlmStart;
        }

        if ( structKeyExists( arguments.context, "result" ) ) {
            runCtx.metrics.lastRawResponse = duplicate( arguments.context.result );
            arguments.context.result = _restoreResponseShape( arguments.context.result, runCtx );
        }
        // Also handle the older "response" key in case a provider uses it.
        else if ( structKeyExists( arguments.context, "response" ) ) {
            runCtx.metrics.lastRawResponse = duplicate( arguments.context.response );
            arguments.context.response = _restoreResponseShape( arguments.context.response, runCtx );
        }

        var elapsed = getTickCount() - start;
        runCtx.metrics.inboundMs    += elapsed;
        runCtx.metrics.lastInboundMs = elapsed;

        // Mirror final state to the public metrics snapshot so the demo UI
        // can read it even if afterAgentRun doesn't fire for this flow.
        variables.lastRunMetrics = duplicate( runCtx.metrics );

        return _proceed();
    }

    /**
     * Load the token-protocol markdown that ships with the module. Host apps
     * can override via `policy.tokenProtocolPath` if they want their own copy.
     * Falls back to a short built-in default if the file can't be read — the
     * module should never silently produce an empty protocol.
     */
    private string function _loadTokenProtocol( string overridePath = "" ) {
        var candidates = [];
        if ( len( arguments.overridePath ) ) {
            candidates.append( arguments.overridePath );
        }
        // The module's bundled copy.
        try {
            candidates.append( expandPath( "/bxAiSentinel/includes/token-protocol.md" ) );
        } catch ( any e ) {}
        try {
            candidates.append(
                getDirectoryFromPath( getCurrentTemplatePath() ) & "../includes/token-protocol.md"
            );
        } catch ( any e ) {}

        for ( var path in candidates ) {
            try {
                if ( len( path ) && fileExists( path ) ) {
                    return fileRead( path );
                }
            } catch ( any e ) {}
        }

        // Fallback — minimal protocol so the module always works.
        return "When you see placeholders of the form ⟦SECRET:LABEL:hmac8⟧ in a message, treat them as opaque tokens that stand in for real sensitive values the user has redacted. Copy them verbatim in any response — do not modify, paraphrase, or guess at the underlying value.";
    }

    /**
     * True iff any message.content in the outbound payload contains a
     * Sentinel token shape. Used to gate token-coaching injection so plain
     * non-sensitive chat doesn't eat context window.
     */
    private boolean function _messagesContainTokens( required array messages ) {
        // Match the FULL canonical token shape ⟦SECRET:LABEL:hmac8⟧, not just
        // the bracket-and-prefix substring. The looser substring marker
        // incorrectly fired on agent / demo system prompts containing example
        // tokens like "⟦SECRET:AWS_ACCESS_KEY:…⟧" (ellipsis, not real hex) —
        // result was coaching ALWAYS firing regardless of whether the host
        // had actually minted any tokens, defeating the "skip overhead on
        // plain chat" optimization.
        //
        // Pattern mirrors Tokenizer.bx's TOKEN_REGEX exactly: 8 hex chars
        // for the HMAC suffix is what distinguishes a minted token from a
        // documentation placeholder.
        var pattern = char( 10214 ) & "SECRET:[A-Z0-9_]+:[a-f0-9]{8}" & char( 10215 );
        for ( var msg in arguments.messages ) {
            if ( isStruct( msg )
                 && structKeyExists( msg, "content" )
                 && isSimpleValue( msg.content )
                 && reFind( pattern, msg.content ) > 0 ) {
                return true;
            }
        }
        return false;
    }

    /**
     * Insert the token-protocol content into the outbound message stream so
     * the LLM sees it as part of its system context. If an existing system
     * message is present, append to it with a separator (bx-ai / LLM best
     * practice is one system message per conversation). Otherwise prepend a
     * new one.
     */
    private function _injectTokenProtocol( required array messages ) {
        var protocolHeader = char( 10 ) & char( 10 ) & "---" & char( 10 ) & "## bx-AISentinel token protocol" & char( 10 ) & char( 10 );
        var injection      = protocolHeader & variables.tokenProtocolContent;

        if ( arrayLen( arguments.messages ) > 0
             && isStruct( arguments.messages[ 1 ] )
             && ( arguments.messages[ 1 ].role ?: "" ) == "system"
             && isSimpleValue( arguments.messages[ 1 ].content ?: "" ) ) {
            arguments.messages[ 1 ].content = arguments.messages[ 1 ].content & injection;
            return;
        }

        arguments.messages.prepend( {
            "role"    : "system",
            "content" : variables.tokenProtocolContent
        } );
    }

    /**
     * Runtime toggle for token coaching. Flipping this doesn't need a
     * rebuild — next beforeLLMCall respects the new value.
     */
    function setExplainTokensToLLM( required boolean enabled ) {
        variables.explainTokensToLLM = arguments.enabled;
        return this;
    }

    boolean function isExplainTokensToLLMEnabled() {
        return variables.explainTokensToLLM;
    }

    /**
     * Extract the outbound messages array from whichever key bx-ai happens to
     * pass it in. Supports:
     *   context.dataPacket.messages   — bx-ai 3.x OpenAI-compatible providers
     *   context.messages              — older / documented shape
     */
    private any function _extractMessagesFromContext( required struct context ) {
        if ( structKeyExists( arguments.context, "dataPacket" )
             && isStruct( arguments.context.dataPacket )
             && structKeyExists( arguments.context.dataPacket, "messages" )
             && isArray( arguments.context.dataPacket.messages ) ) {
            return arguments.context.dataPacket.messages;
        }
        if ( structKeyExists( arguments.context, "messages" )
             && isArray( arguments.context.messages ) ) {
            return arguments.context.messages;
        }
        return javaCast( "null", "" );
    }

    function beforeToolCall( required struct context ) {
        if ( !variables.enabled ) return _proceed();

        var runCtx = _resolveRunContext( arguments.context );
        var start  = getTickCount();

        if ( structKeyExists( arguments.context, "toolArgs" ) ) {
            arguments.context.toolArgs = variables.core.redactStructure( arguments.context.toolArgs, runCtx );
        }

        var elapsed = getTickCount() - start;
        runCtx.metrics.toolRedactMs += elapsed;

        return _proceed();
    }

    function afterToolCall( required struct context ) {
        if ( !variables.enabled ) return _proceed();

        var runCtx = _resolveRunContext( arguments.context );
        var start  = getTickCount();

        if ( structKeyExists( arguments.context, "result" ) ) {
            arguments.context.result = variables.core.restoreStructure( arguments.context.result, runCtx );
        }

        var elapsed = getTickCount() - start;
        runCtx.metrics.toolRestoreMs += elapsed;

        return _proceed();
    }

    /**
     * Default pass-through wrap hooks — bx-ai 3.x invokes these around the
     * actual LLM call / tool invocation. We don't need to intercept at the
     * wrap layer (our before* / after* hooks already do the work), but we
     * MUST implement these so the middleware contract is satisfied.
     */
    any function wrapLLMCall( required struct context, required function handler ) {
        return arguments.handler();
    }

    any function wrapToolCall( required struct context, required function handler ) {
        return arguments.handler();
    }

    function onError( required struct context ) {
        return _proceed();
    }

    function afterAgentRun( required struct context ) {
        if ( !variables.enabled ) return _proceed();

        var runCtx = _resolveRunContext( arguments.context );

        variables.lastRunMetrics = duplicate( runCtx.metrics );

        if ( variables.metricsEnabled ) {
            variables.auditor.runComplete( runCtx.metrics, runCtx.runId );
        }

        // Tear down only when manifest scope is per-run. Conversation scope
        // keeps the manifest alive across multiple agent.run() invocations.
        if ( variables.manifestScope == "run" ) {
            variables.core.teardownRunContext( runCtx );
            variables.persistentRunContext = javaCast( "null", "" );
        }

        return _proceed();
    }

    // ─────────────────────────────────────────────────────────────────────
    // Public inspection API
    // ─────────────────────────────────────────────────────────────────────

    /**
     * Returns the most recently completed run's metrics.
     * Called by the CBWire chat UI to render the per-reply timing badge.
     */
    struct function getLastRunMetrics() {
        return variables.lastRunMetrics;
    }

    /**
     * Register a secret at runtime. Delegates into the RegistryDetector if
     * one was composed into the pipeline.
     */
    function registerSecret(
        required string label,
        required string value,
                 string category = "registry"
    ) {
        for ( var d in variables.core.detectionEngine.getDetectors() ) {
            if ( d.getSourceName() == "RegistryDetector" ) {
                d.register( arguments.label, arguments.value, arguments.category );
                break;
            }
        }
        return this;
    }

    // ─────────────────────────────────────────────────────────────────────
    // Internal helpers
    // ─────────────────────────────────────────────────────────────────────

    /**
     * Resolve the per-run context — either from conversation-scoped persistent
     * state, or by creating a new one if the host somehow called a mid-run
     * hook without `beforeAgentRun` firing first.
     */
    private struct function _getOrCreateRunContext() {
        if ( variables.manifestScope == "conversation" && !isNull( variables.persistentRunContext ) ) {
            return variables.persistentRunContext;
        }

        var runCtx = variables.core.newRunContext();
        if ( variables.manifestScope == "conversation" ) {
            variables.persistentRunContext = runCtx;
        }
        return runCtx;
    }

    /**
     * Fetch runCtx from the context struct, or synthesize one if missing
     * (defensive — shouldn't happen if beforeAgentRun fired).
     */
    private struct function _resolveRunContext( required struct context ) {
        if ( structKeyExists( arguments.context, "metadata" )
             && structKeyExists( arguments.context.metadata, "sentinel" ) ) {
            return arguments.context.metadata.sentinel;
        }

        if ( !structKeyExists( arguments.context, "metadata" ) ) {
            arguments.context.metadata = {};
        }
        arguments.context.metadata.sentinel = _getOrCreateRunContext();
        return arguments.context.metadata.sentinel;
    }

    /**
     * Restore plaintext in whatever shape bx-ai hands us. The response may be:
     *   - a plain string
     *   - a struct with a .content key
     *   - a struct with a .choices array (OpenAI-shape)
     *   - a getContent()-style object
     * Do the best we can to find text fields and restore them, leaving unknown
     * fields untouched.
     *
     * After restoration, optionally appends a brief notice to the user-visible
     * content explaining that the response was post-processed locally — see
     * `_buildRestorationNotice()`. Toggled by the `appendRestorationNotice`
     * policy setting (default true).
     */
    private any function _restoreResponseShape( required any response, required struct runCtx ) {
        var notice = _buildRestorationNotice( arguments.runCtx );

        if ( isSimpleValue( arguments.response ) ) {
            var restored = variables.core.restore( arguments.response, arguments.runCtx );
            return restored & notice;
        }

        if ( isStruct( arguments.response ) ) {
            if ( structKeyExists( arguments.response, "content" ) && isSimpleValue( arguments.response.content ) ) {
                arguments.response.content = variables.core.restore( arguments.response.content, arguments.runCtx ) & notice;
            }

            if ( structKeyExists( arguments.response, "choices" ) && isArray( arguments.response.choices ) ) {
                // Only append the notice to the FIRST choice — alternative
                // completions are typically not user-visible, and duplicating
                // the notice would be noisy.
                var noticed = false;
                for ( var choice in arguments.response.choices ) {
                    if ( isStruct( choice ) && structKeyExists( choice, "message" )
                         && isStruct( choice.message ) && structKeyExists( choice.message, "content" )
                         && isSimpleValue( choice.message.content ) ) {
                        var restored = variables.core.restore( choice.message.content, arguments.runCtx );
                        choice.message.content = noticed ? restored : ( restored & notice );
                        noticed = true;
                    }
                }
            }
        }

        return arguments.response;
    }

    /**
     * Build the optional "Sentinel restored values" notice appended to assistant
     * responses. Returns "" when:
     *   - the policy disabled it (`appendRestorationNotice: false`), OR
     *   - no tokens were minted for this run (no protection happened)
     *
     * Otherwise returns a markdown block ready to concatenate after restored
     * content. Markdown so it renders cleanly in any UI that uses the standard
     * `markdown()` BIF (the demo, ColdBox views, plain renderers).
     *
     * The notice avoids the gaslighting case where the LLM, taught to preserve
     * `⟦SECRET:LABEL:hmac8⟧` placeholders, quotes one in a sentence — after
     * restoration the user reads "the password sekret-prod-1 has been redacted"
     * with no signal that the value was protected end-to-end.
     *
     * Wording note: the notice splits "tokenized" (always happens, gated by
     * tokensMinted > 0) from "restored locally if echoed back" (conditional —
     * only happens when the LLM actually quotes a token in its response). The
     * earlier "tokenized for the LLM and restored locally before display"
     * wording was technically inaccurate when the LLM produced a clean prose
     * answer that didn't echo any tokens (nothing to restore).
     */
    private string function _buildRestorationNotice( required struct runCtx ) {
        if ( !variables.policy.isRestorationNoticeEnabled() ) return "";

        var minted = arguments.runCtx.metrics.tokensMinted ?: 0;
        if ( minted <= 0 ) return "";

        var labels = arguments.runCtx.metrics.labels ?: {};
        var labelKeys = structKeyArray( labels ).sort( "text" );

        var labelDisplay = "";
        if ( arrayLen( labelKeys ) ) {
            var parts = [];
            for ( var k in labelKeys ) {
                var c = labels[ k ];
                parts.append( c > 1 ? ( k & " ×" & c ) : k );
            }
            labelDisplay = " (" & parts.toList( ", " ) & ")";
        }

        var noun = minted == 1 ? "value" : "values";
        var were = minted == 1 ? "was"   : "were";

        return char( 10 ) & char( 10 )
            & "---" & char( 10 )
            & "*🛡️ Sentinel: " & minted & " " & noun & labelDisplay
            & " " & were & " tokenized before reaching the LLM. Restored locally if echoed back.*";
    }

    /**
     * Return `AiMiddlewareResult.continue()` when bx-ai is on the classpath,
     * otherwise a shape-compatible struct so the class stays testable without
     * the module installed.
     *
     * Note: bx-ai 3.x exposes `continue` as a static factory on
     * `bxModules.bxai.models.middleware.AiMiddlewareResult`. In BoxLang, static
     * methods can be invoked via either `::` or `.` notation on the class ref.
     */
    private any function _proceed() {
        try {
            var resultClass = createObject( "component", "bxModules.bxai.models.middleware.AiMiddlewareResult" );
            return resultClass.continue();
        } catch ( any e ) {
            return { "type": "continue" };
        }
    }

    // ─────────────────────────────────────────────────────────────────────
    // External-detector plugin support
    // ─────────────────────────────────────────────────────────────────────

    /**
     * Snapshot of what happened when the detector pipeline was composed.
     * Structure:
     *   {
     *       compatibleContractVersion : "1.0.0",
     *       degraded                  : boolean,   // true if any external detector failed to load
     *       detectors                 : [ { name, status, reason? } ]
     *   }
     *
     * Host apps can surface this in a health endpoint so ops can see when
     * a declared external detector silently fell out of the pipeline.
     */
    struct function getLoadReport() {
        return variables.loadReport;
    }

    /**
     * Resolve one external detector by WireBox ID or fully-qualified class path.
     *
     * Order of resolution:
     *   1. If `id` contains a '.' it's treated as a fully-qualified class path
     *      (e.g. `tests.specs.integration.fixtures.FixtureExternalDetector`)
     *      and instantiated via `createObject( "component", id )`.
     *   2. Otherwise WireBox is consulted via `application.wirebox` (the
     *      ColdBox convention). If WireBox is not available, the resolution
     *      fails softly and the interception point fires.
     *
     * Contract-version compatibility is checked on the resolved instance.
     * Failures at any step log via the auditor, fire the
     * `onSentinelDetectorLoadFailure` interception, mark the detector
     * degraded in `loadReport`, and return null so the caller skips it.
     */
    private any function _resolveExternalDetector(
        required string id,
        required struct options,
        required any    auditor
    ) {
        var reason = "";

        try {
            var instance = _instantiateDetector( arguments.id, arguments.options );

            // Contract compatibility gate — major-version must match.
            var declared = _safeGetContractVersion( instance );
            if ( !_isContractCompatible( declared ) ) {
                reason = "contract version " & declared & " incompatible with " & variables.SUPPORTED_CONTRACT_VERSION;
                _recordDetectorLoadFailure(
                    detectorName             : arguments.id,
                    reason                   : reason,
                    attemptedContractVersion : declared,
                    failureMode              : "contract-mismatch",
                    auditor                  : arguments.auditor
                );
                return javaCast( "null", "" );
            }

            // Light duck-type check — external detectors must expose scan().
            if ( !_detectorSatisfiesContract( instance ) ) {
                reason = "missing required methods (scan / getPriority / getSourceName)";
                _recordDetectorLoadFailure(
                    detectorName             : arguments.id,
                    reason                   : reason,
                    attemptedContractVersion : declared,
                    failureMode              : "contract-mismatch",
                    auditor                  : arguments.auditor
                );
                return javaCast( "null", "" );
            }

            variables.loadReport.detectors.append( {
                "name"   : arguments.id,
                "status" : "loaded"
            } );
            return instance;
        }
        catch ( any e ) {
            reason = len( reason ) ? reason : ( e.message ?: "unknown error" );
            _recordDetectorLoadFailure(
                detectorName             : arguments.id,
                reason                   : reason,
                attemptedContractVersion : "",
                failureMode              : "resolution-error",
                auditor                  : arguments.auditor
            );
            return javaCast( "null", "" );
        }
    }

    private any function _instantiateDetector( required string id, required struct options ) {
        // Class path — test fixtures and non-ColdBox hosts use this.
        if ( find( ".", arguments.id ) > 0 ) {
            var klass = createObject( "component", arguments.id );
            if ( structCount( arguments.options ) ) {
                return klass.init( argumentCollection = arguments.options );
            }
            return klass.init();
        }

        // WireBox ID — ColdBox convention: `DetectorName@ModuleName`.
        if ( !structKeyExists( application, "wirebox" ) ) {
            throw( message: "WireBox is not available — cannot resolve detector by ID. Use a fully-qualified class path instead." );
        }
        return structCount( arguments.options )
            ? application.wirebox.getInstance( name = arguments.id, initArguments = arguments.options )
            : application.wirebox.getInstance( arguments.id );
    }

    private string function _safeGetContractVersion( required any instance ) {
        try {
            return arguments.instance.getContractVersion();
        } catch ( any e ) {
            // Detector doesn't expose getContractVersion — treat as pre-1.0 / missing.
            return "";
        }
    }

    /**
     * Major-version compatibility check. `"1.x.y"` matches `SUPPORTED_CONTRACT_VERSION = "1.0.0"`.
     * Empty / malformed versions fail closed.
     */
    private boolean function _isContractCompatible( required string declared ) {
        if ( !len( arguments.declared ) ) return false;
        var declaredMajor  = listFirst( arguments.declared, "." );
        var supportedMajor = listFirst( variables.SUPPORTED_CONTRACT_VERSION, "." );
        return declaredMajor == supportedMajor;
    }

    /**
     * Verifies an instance exposes the required IDetector surface. Duck-typed:
     * classes that don't inherit from `IDetector.bx` are fine as long as they
     * expose the right methods.
     */
    private boolean function _detectorSatisfiesContract( required any instance ) {
        return structKeyExists( arguments.instance, "scan" )
            && structKeyExists( arguments.instance, "getPriority" )
            && structKeyExists( arguments.instance, "getSourceName" );
    }

    private function _recordDetectorLoadFailure(
        required string detectorName,
        required string reason,
        required string attemptedContractVersion,
        required string failureMode,
        required any    auditor
    ) {
        variables.loadReport.degraded = true;
        variables.loadReport.detectors.append( {
            "name"   : arguments.detectorName,
            "status" : "degraded",
            "reason" : arguments.reason
        } );

        arguments.auditor.warnDetectorError(
            arguments.detectorName,
            "load failed (" & arguments.failureMode & "): " & arguments.reason
        );

        _fireInterception( "onSentinelDetectorLoadFailure", {
            "detectorName"             : arguments.detectorName,
            "reason"                   : arguments.reason,
            "attemptedContractVersion" : arguments.attemptedContractVersion,
            "supportedContractVersion" : variables.SUPPORTED_CONTRACT_VERSION,
            "failureMode"              : arguments.failureMode
        } );
    }

    /**
     * Fire a ColdBox interception, best-effort. Swallows any failure — the
     * auditor log is the authoritative record; interception is just the
     * developer's escalation hook.
     */
    private function _fireInterception( required string event, required struct data ) {
        try {
            if ( !structKeyExists( application, "cbController" ) ) return;
            application.cbController.getInterceptorService().announce( arguments.event, arguments.data );
        } catch ( any e ) {
            // Swallow — already logged via auditor.
        }
    }

}
